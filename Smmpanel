<?php
namespace App\Http\Controllers\Admin;
use App\Http\Controllers\Controller;
use App\Models\Service;
use Illuminate\Http\Request;
class DashboardController extends Controller {
    public function index(){
        $services = Service::all();
        return view('admin.dashboard', compact('services'));
    }
    public function importMockProvider(Request $req){
        // simple mock: add sample services
        for($i=1;$i<=5;$i++){
            Service::create(['title'=>"Mock Service #{$i}", 'desc'=>"Imported from mock provider", 'price'=>rand(10,500),'min'=>1,'max'=>10000]);
        }
        return redirect()->route('admin.dashboard')->with('success','Imported 5 mock services.');
    }
}
PHP

cat > app/Http/Controllers/Api/OrderController.php <<'PHP'
<?php
namespace App\Http\Controllers\Api;
use App\Http\Controllers\Controller;
use Illuminate\Http\Request;
use App\Models\Order;
use App\Models\Service;
class OrderController extends Controller {
    public function create(Request $req){
        $user = $req->user();
        $service = Service::findOrFail($req->service_id);
        $quantity = intval($req->quantity);
        $price = $service->price * $quantity;
        $order = Order::create(['user_id'=>$user->id,'service_id'=>$service->id,'quantity'=>$quantity,'price'=>$price,'status'=>'processing']);
        // simulate provider processing (in real code call provider API)
        $order->update(['status'=>'completed','provider_order_id'=>'MOCK-'.rand(1000,9999)]);
        return response()->json(['success'=>true,'order'=>$order]);
    }
}
