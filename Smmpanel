#!/bin/bash
# build_smmslice_full.sh
# Full Laravel SMM Panel auto-builder (sandbox-ready)
# Requirements: php (8.1+), composer, mysql client, node/npm, zip
# Usage: chmod +x build_smmslice_full.sh && ./build_smmslice_full.sh

set -euo pipefail

PROJECT_NAME="smm-panel-smmslice"
DB_NAME="smm_slice_db"
DB_USER="root"
DB_PASS=""
DB_HOST="127.0.0.1"
DB_PORT="3306"

LICENSE_KEY="SMMSLICE-2025-HYBRID-KEY-987654321"
ADMIN_EMAIL="smmshope@gmail.com"
ADMIN_PASS="Password@123"   # change after install
CUSTOMER_EMAIL="buyer@example.com"
CUSTOMER_PASS="BuyerPass123"

BASE_CURRENCY="INR"

# Payment placeholders (sandbox/test)
STRIPE_KEY="pk_test_xxx"
STRIPE_SECRET="sk_test_xxx"
PAYPAL_CLIENT_ID="paypal_test_client_id"
PAYPAL_SECRET="paypal_test_secret"
RAZORPAY_KEY="rzp_test_xxx"
RAZORPAY_SECRET="rzp_test_secret"
COINPAYMENTS_MERCHANT_ID="cp_test_mid"
COINPAYMENTS_SECRET="cp_test_secret"

echo "=== START: Building $PROJECT_NAME ==="

# create Laravel project
if [ -d "$PROJECT_NAME" ]; then
  echo "Project folder already exists. Removing it."
  rm -rf "$PROJECT_NAME"
fi

composer create-project --prefer-dist laravel/laravel "$PROJECT_NAME" || { echo "composer create-project failed"; exit 1; }
cd "$PROJECT_NAME"

echo "=== Creating .env ==="
cp .env.example .env

# write DB and keys to .env
php -r "
\$env = file_get_contents('.env');
\$env = preg_replace('/DB_DATABASE=.*/', 'DB_DATABASE=$DB_NAME', \$env);
\$env = preg_replace('/DB_USERNAME=.*/', 'DB_USERNAME=$DB_USER', \$env);
\$env = preg_replace('/DB_PASSWORD=.*/', 'DB_PASSWORD=$DB_PASS', \$env);
file_put_contents('.env', \$env);
"

# append custom env values
cat >> .env <<EOL

LICENSE_KEY=$LICENSE_KEY
ADMIN_EMAIL=$ADMIN_EMAIL
ADMIN_PASSWORD=$ADMIN_PASS
BASE_CURRENCY=$BASE_CURRENCY

STRIPE_KEY=$STRIPE_KEY
STRIPE_SECRET=$STRIPE_SECRET

PAYPAL_CLIENT_ID=$PAYPAL_CLIENT_ID
PAYPAL_SECRET=$PAYPAL_SECRET

RAZORPAY_KEY=$RAZORPAY_KEY
RAZORPAY_SECRET=$RAZORPAY_SECRET

COINPAYMENTS_MERCHANT_ID=$COINPAYMENTS_MERCHANT_ID
COINPAYMENTS_SECRET=$COINPAYMENTS_SECRET

APP_URL=http://localhost
EOL

echo "=== Attempting to create DB (if mysql user allows) ==="
if mysql -u"$DB_USER" -p"$DB_PASS" -h "$DB_HOST" -P "$DB_PORT" -e "CREATE DATABASE IF NOT EXISTS \`$DB_NAME\` CHARACTER SET utf8mb4 COLLATE utf8mb4_unicode_ci;"; then
  echo "Database ready: $DB_NAME"
else
  echo "Could not create DB automatically. Make sure $DB_NAME exists or edit the script."
fi

# create app directories and basic files
mkdir -p app/Http/Controllers/Admin app/Http/Controllers/Api app/Http/Controllers/Auth app/Services app/Models resources/views/admin resources/views/customer resources/views/auth database/migrations database/seeders routes/api

echo "=== Adding License Middleware ==="
cat > app/Http/Middleware/CheckLicense.php <<'PHP'
<?php
namespace App\Http\Middleware;
use Closure;
use Illuminate\Http\Request;
class CheckLicense {
    public function handle(Request $request, Closure $next) {
        $key = env('LICENSE_KEY');
        if (!$key) {
            abort(403, 'License key missing.');
        }
        // For demo: accept our pre-generated key, or you can implement HMAC validation
        if ($key !== trim('SMMSLICE-2025-HYBRID-KEY-987654321')) {
            abort(403, 'Invalid license.');
        }
        return $next($request);
    }
}
PHP

# Register middleware in Kernel (append to $middlewareGroups 'web')
php -r '
$k = file_get_contents("app/Http/Kernel.php");
if (strpos($k, "App\\\\Http\\\\Middleware\\\\CheckLicense::class") === false) {
    $k = str_replace("\'web\' => [", "\'web\' => [\n            \\App\\Http\\Middleware\\CheckLicense::class,", $k);
    file_put_contents("app/Http/Kernel.php", $k);
    echo "Middleware registered in Kernel.\n";
} else {
    echo "Middleware already present.\n";
}
'

echo "=== Adding Models, Migrations and Seeders ==="

# User model exists; create Service, Order, Provider, Payment models & migrations (simple)
php <<'PHPCODE'
<?php
// create migration files quickly using raw file writes for portability
$ts = time();
$migrations = [
    ['create_services_table', "<?php\nuse Illuminate\\Database\\Migrations\\Migration;\nuse Illuminate\\Database\\Schema\\Blueprint;\nuse Illuminate\\Support\\Facades\\Schema;\n\nreturn new class extends Migration {\n    public function up(){ Schema::create('services', function(Blueprint \$table){\$table->id();\$table->string('title');\$table->text('desc')->nullable();\$table->decimal('price',14,2); \$table->integer('min')->default(1); \$table->integer('max')->default(10000); \$table->timestamps();});}\n    public function down(){ Schema::dropIfExists('services'); }\n};"],
    ['create_providers_table', "<?php\nuse Illuminate\\Database\\Migrations\\Migration;\nuse Illuminate\\Database\\Schema\\Blueprint;\nuse Illuminate\\Support\\Facades\\Schema;\n\nreturn new class extends Migration {\n    public function up(){ Schema::create('providers', function(Blueprint \$table){\$table->id();\$table->string('name');\$table->string('api_endpoint')->nullable();\$table->string('api_key')->nullable();\$table->boolean('active')->default(true); \$table->timestamps();});}\n    public function down(){ Schema::dropIfExists('providers'); }\n};"],
    ['create_orders_table', "<?php\nuse Illuminate\\Database\\Migrations\\Migration;\nuse Illuminate\\Database\\Schema\\Blueprint;\nuse Illuminate\\Support\\Facades\\Schema;\n\nreturn new class extends Migration {\n    public function up(){ Schema::create('orders', function(Blueprint \$table){\$table->id();\$table->unsignedBigInteger('user_id');\$table->unsignedBigInteger('service_id');\$table->integer('quantity');\$table->decimal('price',14,2);\$table->string('status')->default('pending');\$table->string('provider_order_id')->nullable();\$table->timestamps();});}\n    public function down(){ Schema::dropIfExists('orders'); }\n};"],
    ['create_payments_table', "<?php\nuse Illuminate\\Database\\Migrations\\Migration;\nuse Illuminate\\Database\\Schema\\Blueprint;\nuse Illuminate\\Support\\Facades\\Schema;\n\nreturn new class extends Migration {\n    public function up(){ Schema::create('payments', function(Blueprint \$table){\$table->id();\$table->unsignedBigInteger('user_id');\$table->unsignedBigInteger('order_id')->nullable();\$table->decimal('amount',14,2);\$table->string('gateway');\$table->string('status')->default('pending');\$table->string('transaction_id')->nullable();\$table->timestamps();});}\n    public function down(){ Schema::dropIfExists('payments'); }\n};"]
];

foreach($migrations as $i => $m){
    $name = date('Y_m_d_His', time()+$i) . "_{$m[0]}.php";
    file_put_contents("database/migrations/{$name}", $m[1]);
}
echo "Migrations created.\n";
PHPCODE

